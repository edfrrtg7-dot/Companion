{
  "manifest_version": 3,
  "name": "Companion",
  "description": "Modular productivity platform for GoldenBride CRM",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [],
  "host_permissions": [
    "https://goldenbride.net/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://goldenbride.net/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
